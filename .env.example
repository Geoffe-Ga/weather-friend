# Discord Bot Configuration
DISCORD_TOKEN=your-discord-bot-token
DISCORD_CHANNEL_ID=your-channel-id

# OpenWeatherMap API
OPENWEATHER_API_KEY=your-openweathermap-key

# Anthropic Claude API
